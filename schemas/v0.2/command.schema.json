{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocad-ai.local/schemas/v0.2/command.schema.json",
  "title": "AutoCAD-AI Command v0.2",
  "description": "Traceable command contract for AutoCAD-AI operations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "import_id",
    "command_id",
    "submitted_at",
    "application",
    "operation",
    "parameters",
    "units",
    "coordinate_system",
    "requires_approval"
  ],
  "properties": {
    "schema_version": {
      "const": "0.2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "import_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "command_id": {
      "type": "string",
      "minLength": 1
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "application": {
      "const": "autocad"
    },
    "operation": {
      "const": "create_line"
    },
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end",
        "layer",
        "create_layer_if_missing"
      ],
      "properties": {
        "start": {
          "$ref": "#/$defs/point3d"
        },
        "end": {
          "$ref": "#/$defs/point3d"
        },
        "layer": {
          "type": "string",
          "minLength": 1
        },
        "create_layer_if_missing": {
          "type": "boolean"
        }
      }
    },
    "units": {
      "enum": [
        "inches",
        "feet",
        "millimeters",
        "centimeters",
        "meters"
      ]
    },
    "coordinate_system": {
      "const": "world"
    },
    "requires_approval": {
      "const": false
    }
  },
  "$defs": {
    "point3d": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    }
  }
}
