{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autocad-ai.local/schemas/v0.4/command.schema.json",
  "title": "AutoCAD-AI Atomic Batch Command v0.4",
  "description": "A validate-only or atomic line/polyline batch command.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "import_id",
    "command_id",
    "submitted_at",
    "application",
    "operation",
    "parameters",
    "units",
    "coordinate_system",
    "requires_approval"
  ],
  "properties": {
    "schema_version": {
      "const": "0.4"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "import_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "command_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "application": {
      "const": "autocad"
    },
    "operation": {
      "const": "execute_batch"
    },
    "parameters": {
      "$ref": "#/$defs/batch_parameters"
    },
    "units": {
      "enum": [
        "inches",
        "feet",
        "millimeters",
        "centimeters",
        "meters"
      ]
    },
    "coordinate_system": {
      "const": "world"
    },
    "requires_approval": {
      "const": false
    }
  },
  "$defs": {
    "batch_parameters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validate_only",
        "expected_document",
        "entities"
      ],
      "properties": {
        "validate_only": {
          "type": "boolean"
        },
        "expected_document": {
          "$ref": "#/$defs/expected_document"
        },
        "entities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 500,
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/line_entity"
              },
              {
                "$ref": "#/$defs/polyline_entity"
              }
            ]
          }
        }
      }
    },
    "expected_document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 260
        },
        "fingerprint_guid": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{4}-[0-9A-Fa-f]{12}$"
        }
      }
    },
    "entity_common": {
      "type": "object",
      "properties": {
        "client_entity_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "layer": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "create_layer_if_missing": {
          "type": "boolean"
        }
      },
      "required": [
        "client_entity_id",
        "layer",
        "create_layer_if_missing"
      ]
    },
    "line_entity": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_common"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "client_entity_id",
            "entity_type",
            "layer",
            "create_layer_if_missing",
            "start",
            "end"
          ],
          "properties": {
            "client_entity_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "entity_type": {
              "const": "line"
            },
            "layer": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "create_layer_if_missing": {
              "type": "boolean"
            },
            "start": {
              "$ref": "#/$defs/point3d"
            },
            "end": {
              "$ref": "#/$defs/point3d"
            }
          }
        }
      ]
    },
    "polyline_entity": {
      "allOf": [
        {
          "$ref": "#/$defs/entity_common"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "client_entity_id",
            "entity_type",
            "layer",
            "create_layer_if_missing",
            "vertices",
            "closed"
          ],
          "properties": {
            "client_entity_id": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "entity_type": {
              "const": "polyline"
            },
            "layer": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255
            },
            "create_layer_if_missing": {
              "type": "boolean"
            },
            "vertices": {
              "type": "array",
              "minItems": 2,
              "maxItems": 50000,
              "items": {
                "$ref": "#/$defs/point3d"
              }
            },
            "closed": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "point3d": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "z"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        }
      }
    }
  }
}
